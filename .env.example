# Apoffa — Example Environment Variables
# Copy to .env.local and fill in your values
# Never commit .env.local to Git

# ── Application ───────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME=Apoffa
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_DEMO_MODE=false

# ── Supabase ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Database (Prisma) ─────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:54322/postgres?schema=public
DIRECT_URL=postgresql://postgres:postgres@localhost:54322/postgres?schema=public

# ── Search ────────────────────────────────────────────────────────────────
SEARCH_PROVIDER=postgres
MEILISEARCH_HOST=http://127.0.0.1:7700
MEILISEARCH_API_KEY=
MEILISEARCH_INDEX=case_decisions

# ── RAG / AI ──────────────────────────────────────────────────────────────
LLM_PROVIDER=mock
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=gemma2:9b
CUSTOM_HTTP_URL=
CUSTOM_HTTP_KEY=
CUSTOM_HTTP_MODEL=
EMBEDDING_PROVIDER=mock
EMBEDDING_DIMENSION=768

# ── Ingestion ─────────────────────────────────────────────────────────────
ENABLE_PERIODIC_RECON=false
RECON_INTERVAL_MS=3600000
ENABLE_IMPORT=false
IMPORT_PATH=./data/raw
MAX_IMPORT_FILES=100

# ── Worker ────────────────────────────────────────────────────────────────
WORKER_CONCURRENCY=2
WORKER_POLL_INTERVAL_MS=5000
WORKER_HEALTH_PORT=8080

# ── Monitoring ────────────────────────────────────────────────────────────
SENTRY_DSN=

# ── Feature Flags ─────────────────────────────────────────────────────────
ENABLE_GRAPH_EXTRACTION=false

# .env.example
# Copy to .env and fill in your values

# Application
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Database (Prisma + PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/apoffa?schema=public
DIRECT_URL=postgresql://user:password@localhost:5432/apoffa?schema=public

# Redis (Upstash)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# OpenAI
OPENAI_API_KEY=

# Optional: LangSmith tracing
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=

# Optional: Anthropic
ANTHROPIC_API_KEY=

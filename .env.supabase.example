# Apoffa — Supabase Production Environment Variables
# These are used for Supabase CLI and production deployments

# ── Supabase Project ──────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_PROJECT_ID=your-project-id

# ── Database (connection pooler) ──────────────────────────────────────────
DATABASE_URL=postgresql://postgres:[password]@db.[project].supabase.co:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres:[password]@db.[project].supabase.co:5432/postgres

# ── Application ───────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME=Apoffa
NEXT_PUBLIC_APP_URL=https://apoffa.com
NODE_ENV=production

# ── Search ────────────────────────────────────────────────────────────────
SEARCH_PROVIDER=postgres

# ── RAG / AI (production provider) ────────────────────────────────────────
LLM_PROVIDER=custom
CUSTOM_HTTP_URL=https://api.openai.com/v1
CUSTOM_HTTP_KEY=your-openai-key
CUSTOM_HTTP_MODEL=gpt-4o-mini
EMBEDDING_PROVIDER=custom
CUSTOM_HTTP_EMBEDDING_URL=https://api.openai.com/v1
CUSTOM_HTTP_EMBEDDING_KEY=your-openai-key
CUSTOM_HTTP_EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=1536

# ── Worker ────────────────────────────────────────────────────────────────
WORKER_CONCURRENCY=4
WORKER_POLL_INTERVAL_MS=5000
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Monitoring ────────────────────────────────────────────────────────────
SENTRY_DSN=

# ── Feature Flags ─────────────────────────────────────────────────────────
ENABLE_GRAPH_EXTRACTION=true
